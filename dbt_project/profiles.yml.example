# profiles.yml.example
#
# This is a TEMPLATE. dbt's actual profiles.yml lives outside the repo at
# ~/.dbt/profiles.yml and is never committed to git, since it holds credentials.
#
# Setup:
#   1. Create the folder if it doesn't exist:      mkdir -p ~/.dbt
#   2. Copy this file there:                        cp profiles.yml.example ~/.dbt/profiles.yml
#   3. Edit ~/.dbt/profiles.yml with your local Postgres username/password
#      (on Mac with Homebrew Postgres, user is usually your Mac username and
#      password is often blank, since local trust auth is the default)

unified_commerce:
  target: dev
  outputs:
    dev:
      type: postgres
      host: localhost
      port: 5432
      user: YOUR_MAC_USERNAME
      password: ""
      dbname: unified_commerce
      schema: dbt_dev
      threads: 4
